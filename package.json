{
	"name": "interface",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/postbuild.mjs",
		"preview": "wrangler dev",
		"deploy": "vite build && wrangler deploy",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"@vitest/coverage-istanbul": "^4.1.5",
		"esbuild": "^0.28.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.5",
		"typescript": "^5.5.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.87.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.92.0",
		"@mozilla/readability": "^0.6.0",
		"@openrouter/sdk": "^0.12.24",
		"katex": "^0.16.45",
		"linkedom": "^0.18.12",
		"marked": "^14.1.4",
		"marked-katex-extension": "^5.1.8",
		"marked-shiki": "^1.2.1",
		"shiki": "^4.0.2",
		"ynab": "^4.1.0"
	}
}

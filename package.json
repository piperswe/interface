{
	"dependencies": {
		"@anthropic-ai/sdk": "^0.92.0",
		"@cloudflare/sandbox": "^0.9.2",
		"@mozilla/readability": "^0.6.0",
		"@openrouter/sdk": "^0.12.24",
		"bootstrap": "^5.3.8",
		"dompurify": "^3.4.2",
		"katex": "^0.16.45",
		"linkedom": "^0.18.12",
		"lucide-svelte": "^1.0.1",
		"marked": "^14.1.4",
		"marked-katex-extension": "^5.1.8",
		"marked-shiki": "^1.2.1",
		"mermaid": "^11.14.0",
		"mime-db": "^1.54.0",
		"monaco-editor": "^0.55.1",
		"openai": "^6.36.0",
		"shiki": "^4.0.2",
		"ynab": "^4.1.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/mime-db": "^1.43.6",
		"@types/node": "^25.6.0",
		"@vitest/coverage-istanbul": "^4.1.5",
		"esbuild": "^0.28.0",
		"sass": "^1.99.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.5",
		"typescript": "^5.5.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.87.0"
	},
	"name": "interface",
	"private": true,
	"scripts": {
		"build": "node --loader ./node-loader.mjs node_modules/.bin/vite build && node scripts/postbuild.mjs",
		"cf-typegen": "wrangler types",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && node scripts/check-remote-form-usage.mjs && biome check .",
		"deploy": "node --loader ./node-loader.mjs node_modules/.bin/vite build && wrangler deploy",
		"dev": "vite dev",
		"format": "biome format --write .",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"migrate": "wrangler d1 migrations apply interface --remote",
		"preview": "wrangler dev",
		"test": "svelte-kit sync && node scripts/run-tests.mjs",
		"test:coverage": "svelte-kit sync && node scripts/run-tests.mjs --coverage",
		"test:watch": "svelte-kit sync && vitest",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && node scripts/check-remote-form-usage.mjs"
	},
	"type": "module",
	"version": "0.0.0"
}

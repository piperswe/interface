/**
 * Wrangler configuration. The Worker entry is the SvelteKit cloudflare
 * adapter's output (`.svelte-kit/cloudflare/_worker.js`); a postbuild step
 * (`scripts/postbuild.mjs`) appends a `ConversationDurableObject` re-export
 * so wrangler picks the DO class up at deploy time. See AGENTS.md.
 *
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "interface",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2026-04-22",
	"compatibility_flags": ["nodejs_compat"],
	"migrations": [
		{
			"new_sqlite_classes": ["ConversationDurableObject"],
			"tag": "v1",
		},
		{
			"new_sqlite_classes": ["Sandbox"],
			"tag": "v2",
		},
	],
	"containers": [
		{
			"class_name": "Sandbox",
			"image": "./Dockerfile",
			"instance_type": "lite",
			"max_instances": 10,
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "ConversationDurableObject",
				"name": "CONVERSATION_DURABLE_OBJECT",
			},
			{
				"class_name": "Sandbox",
				"name": "SANDBOX",
			},
		],
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "interface",
			"database_id": "45f097c8-b921-4034-b580-c1ac47e0b2db",
			"migrations_dir": "migrations",
		},
	],
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	"minify": true,
	"placement": { "mode": "smart" },
	// Required secrets are listed below. Optional provider keys
	// (ANTHROPIC_KEY, OPENAI_KEY, GOOGLE_KEY, DEEPSEEK_KEY, KAGI_KEY,
	// YNAB_TOKEN) are declared in src/app.d.ts and resolved via routeLLM /
	// settings / per-tool factories.
	"secrets": {
		"required": ["OPENROUTER_KEY"],
	},
	"assets": {
		"directory": ".svelte-kit/cloudflare",
		"binding": "ASSETS",
	},
	"routes": [
		{
			"pattern": "interface.piperswe.me",
			"custom_domain": true,
		},
	],
}
